{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  assignees: [
    "@A1994SC"
  ],
  automerge: true,
  platformAutomerge: true,
  ignoreUnstable: false,
  separateMajorMinor: false,
  dependencyDashboard: true,
  packageRules: [],
  customManagers: [
    {
      customType: "regex",
      description: [
        "custom regex for dealing with zarf packages inside bundles"
      ],
      managerFilePatterns: [
        "/(^|/).+\\.ya?ml(\\.j2)?$/"
      ],
      matchStrings: [
        "(?m:^ +repository: (?<depName>.+)\n +ref: (?<currentValue>.+) # renovate:(?: versioning=(?<versioning>.+))?$)",
        "(?m:# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\n.+?(?<currentValue>v?(?:[0-9]+\\.?){3,4}(?:-.+)?)[\\'\"]?$)",
        "(?m:# renovate: datasource=(?<datasource>\\S+)\n.+: (?:oci:/{2})?(?<depName>[a-z0-9\\.].+):(?<currentValue>v?([0-9]+\\.?){3}(-.+)?$))"
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}",
    },
  ],
}
